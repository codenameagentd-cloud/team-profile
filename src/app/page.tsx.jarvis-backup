import Link from "next/link";

const members = [
  {
    id: "lisa",
    role: "Lead Coordinator",
    name: "Lisa",
    oneliner: "I make sure everything lands.",
    about: "Lisa is the connective tissue of the team. She turns ambiguity into action, keeps momentum when energy dips, and makes sure nothing falls through the cracks. She does not just organise — she orchestrates.",
    photo: "/photos/photo4-black-cat.jpg",
  },
